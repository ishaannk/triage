# =========================================================================
# Triage environment. Copy to `.env` and fill in the keys you have.
# Everything runs against remote APIs; NO local model weights are used.
# Any provider without a key is automatically skipped and its models fall
# back to the built-in MOCK provider, so the app still runs end-to-end.
# =========================================================================

# ---- OpenAI / GPT (the paid hard-task lane) ----
# Returns token logprobs -> Triage's uncertainty signal is FREE from the main
# pass. Once this is set, models gpt-4o-mini/gpt-4o (and gpt-5-mini/gpt-5) go live.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- NVIDIA NIM (OpenAI-compatible) ----
# Get a key at https://build.nvidia.com  (personal key -> "Generate API Key")
nvidia=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ---- Groq (OpenAI-compatible) ----
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- Ollama Cloud (optional; models are UI-hidden — NVIDIA is the curated free lane) ----
# https://ollama.com to create a key. `ollamacloud=` also accepted.
ollamacloud=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com

# ---- HuggingFace Inference ----
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx
HF_BASE_URL=https://api-inference.huggingface.co

# ---- Retrieval backend: "local" (numpy/FAISS fallback) or "pgvector" ----
RETRIEVAL_BACKEND=local
# Used only when RETRIEVAL_BACKEND=pgvector (matches docker-compose.yml)
PG_DSN=postgresql://svserve:svserve@localhost:5433/svserve

# ---- Telemetry (SQLite path) ----
TELEMETRY_DB=data/telemetry.db

# ---- Force every model onto the mock provider (offline demo, no network) ----
TRIAGE_FORCE_MOCK=0
